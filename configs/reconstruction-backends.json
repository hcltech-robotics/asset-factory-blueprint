      "primary_output_name": "asset.glb",
      "gpu_requirements": {
        "cuda": true,
        "min_vram_gb": 16
      },
      "timeout_seconds": 7200,
      "allowed_paths": [
        "projects",
        "artifacts",
        ".cache/afb",
        "library/downloads"
      ]
    },
