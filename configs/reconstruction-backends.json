{
  "version": "1.0",
  "adapter": {
    "model_kind": "local-reconstruction-adapter",
    "input_schema": "schemas/source-asset-manifest.schema.json",
    "output_schema": "schemas/reconstruction-manifest.schema.json",
    "runner": "scripts/reconstruction/run_reconstruction_backend.py",
    "provisioner": "scripts/reconstruction/provision_reconstruction_backend.py"
  },
  "backends": [
    {
      "id": "trellisv2",
      "display_name": "Trellis v2",
      "aliases": [
        "trellis",
        "trellis2",
        "trellis.2",
        "trellisv2"
      ],
      "provider": "local",
      "model_ref": "microsoft/TRELLIS.2-4B",
      "accepted_inputs": [
        "image/png",
        "image/jpeg",
        "image/webp"
      ],
      "produces": [
        "model/gltf-binary",
        "video/mp4"
      ],
      "path_env_vars": [
        "AFB_TRELLISV2_ROOT",
        "TRELLIS2_ROOT",
        "TRELLIS_ROOT"
      ],
      "candidate_roots": [
        ".cache/afb/backends/TRELLIS.2"
      ],
      "required_files": [
        "app.py",
        "example.py",
        "setup.sh",
        "trellis2/__init__.py"
      ],
      "weights_roots": [],
      "adapter_script": "scripts/reconstruction/backend_adapters/trellis2_image_to_glb.py",
      "native_command": [
        "python",
        "scripts/reconstruction/backend_adapters/trellis2_image_to_glb.py",
        "--backend-root",
        "{backend_root}",
        "--image",
        "{input_asset}",
        "--output-dir",
        "{output_dir}",
        "--model-ref",
        "{model_ref}"
      ],
      "primary_output_name": "asset.glb",
      "gpu_requirements": {
        "cuda": true,
        "min_vram_gb": 24
      },
      "timeout_seconds": 7200,
      "allowed_paths": [
        "projects",
        "artifacts",
        ".cache/afb",
        "library/downloads"
      ]
    },
    {
      "id": "hunyuan3d",
