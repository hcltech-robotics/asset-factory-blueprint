      "stage": "material-inference",
      "defect_tags": [
        "implausible_material",
        "material_contradicts_photo",
        "missing_component_material"
      ],
      "symptom": "the material story contradicts the photos or leaves components uncovered",
      "cause": "weak metadata or a wrong constrained-library pick",
      "action": {
        "kind": "tool",
        "tool": "material_propose",
        "params_template": {}
      },
      "max_attempts": 1,
      "reverify": [
        "material-evidence",
