{
  "version": "1.0",
  "default_max_attempts": 2,
  "fixes": [
    {
      "fix_id": "heal_mesh_holes",
      "stage": "reconstruction",
      "defect_tags": [
        "mesh_holes"
      ],
      "symptom": "renders show gaps or the mesh is reported non-watertight",
      "cause": "generative backends often emit open shells and unwelded seams",
      "action": {
        "kind": "tool",
        "tool": "asset_mesh_condition",
        "params_template": {
          "operations": [
            {
              "operation": "heal",
              "fill_holes": true,
              "cap_boundaries": true
            }
          ]
        }
      },
      "max_attempts": 2,
      "reverify": [
        "schema-valid",
        "vlm-signoff"
      ],
      "escalation": "review_required"
    },
    {
      "fix_id": "smooth_lumpy_region",
      "stage": "reconstruction",
      "defect_tags": [
        "lumpy_surface"
      ],
      "symptom": "a region the source photos show as smooth renders lumpy or melted",
      "cause": "reconstruction noise on low-texture regions",
      "action": {
        "kind": "tool",
        "tool": "asset_mesh_condition",
        "params_template": {
          "operations": [
            {
              "operation": "smooth",
              "iterations": 12
            }
          ]
        }
      },
      "max_attempts": 2,
      "reverify": [
        "vlm-signoff"
      ],
      "escalation": "review_required"
    },
    {
      "fix_id": "prune_floating_fragments",
      "stage": "reconstruction",
      "defect_tags": [
        "fragmented_parts",
        "extra_geometry"
      ],
      "symptom": "disconnected shards or geometry not present in the source photos",
      "cause": "backend hallucination or background bleed into the reconstruction",
      "action": {
        "kind": "tool",
        "tool": "asset_mesh_condition",
        "params_template": {
          "operations": [
            {
              "operation": "heal",
              "prune_components": true,
              "min_component_fraction": 0.01
            }
          ]
        }
      },
      "max_attempts": 1,
      "reverify": [
        "vlm-signoff"
      ],
      "escalation": "review_required"
    },
    {
      "fix_id": "rerun_reconstruction_fallback_backend",
      "stage": "reconstruction",
      "defect_tags": [
        "missing_parts",
        "wrong_proportions",
        "wrong_scale"
      ],
      "symptom": "structural defects that mesh conditioning cannot repair",
      "cause": "the selected backend could not recover the object structure from the conditioning views",
      "action": {
        "kind": "capability_fallback",
        "capability_id": "reconstruction.image_to_3d",
        "note": "regenerate with the next ready backend from the capability registry, reusing the segmentation prior"
      },
      "max_attempts": 1,
      "reverify": [
        "schema-valid",
        "vlm-signoff"
      ],
      "escalation": "review_required"
    },
    {
      "fix_id": "rerun_segmentation_prior_stronger_method",
      "stage": "segmentation",
      "defect_tags": [
        "missing_segment",
        "mask_misaligned",
        "merged_segments",
        "oversplit_segments"
      ],
      "symptom": "segment masks do not carve the object into the expected regions",
      "cause": "the appearance heuristic or the selected segmentation model underperformed on this image",
      "action": {
        "kind": "tool",
        "tool": "asset_image_segmentation_prior",
        "params_template": {
          "method": "sam3.1"
        }
      },
      "max_attempts": 2,
      "reverify": [
        "segmentation-segments",
        "vlm-signoff"
      ],
      "escalation": "review_required"
    },
    {
      "fix_id": "relabel_segments",
      "stage": "segmentation",
      "defect_tags": [
        "wrong_semantic_label"
      ],
      "symptom": "a mask covers the right region under the wrong semantic label",
      "cause": "label assignment from weak appearance priors",
      "action": {
        "kind": "tool",
        "tool": "asset_image_segmentation_prior",
        "params_template": {
          "method": "auto"
        }
      },
      "max_attempts": 1,
      "reverify": [
        "vlm-signoff"
      ],
      "escalation": "review_required"
    },
    {
