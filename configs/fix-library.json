      ],
      "escalation": "review_required"
    },
    {
      "fix_id": "escalate_physical_value",
      "stage": "material-inference",
      "defect_tags": [
        "implausible_physical_value"
      ],
      "symptom": "a proposed mass, density or friction value is grossly implausible",
      "cause": "default priors applied without measurement",
      "action": {
        "kind": "escalate",
        "note": "numeric physical values are never auto-fixed; the proposal is marked review_required with the finding attached"
      },
      "max_attempts": 0,
      "reverify": [],
      "escalation": "review_required"
    },
