{
  "id": "benchmark-1-reproducibility",
  "version": "1.0",
  "status": "proposal",
  "repeat_count": 5,
  "source_cache_layout": {
    "images": "sources/images",
    "usd_archive": "sources/usd/Industrial_NVD_10012.zip",
    "usd_extract": "sources/usd/industrial",
    "runs": "runs"
  },
  "image_reconstruction": {
    "backend_id": "trellisv2",
    "model_ref": "microsoft/TRELLIS.2-4B",
    "reproducibility": {
      "seed": 17,
      "deterministic": true,
      "pipeline_type": "512",
      "dtype": "float32",
      "max_num_tokens": 49152,
      "decimation_target": 1000000,
      "texture_size": 4096,
      "prune_unused_models": true,
      "cpu_image_cond": true,
      "skip_preprocess": false
    }
  },
  "mesh_verification": {
    "mandatory": true,
    "agent_id": "mesh-verification-agent",
    "provider": "nvidia_nim",
    "model": "meta/llama-3.2-90b-vision-instruct",
    "seed": 17,
    "temperature": 0.0,
    "max_review_attempts": 4,
    "max_inference_resubmissions": 3,
    "max_total_inference_attempts": 4,
    "retry_seed_stride": 1,
    "rejection_policy": "adaptive_conditioning_same_backend",
    "quality_policy": {
      "profile": "appearance_mesh",
      "require_watertight": false,
      "require_winding_consistent": false,
      "require_genus_defined": false,
      "max_component_count": 30000,
      "max_boundary_edge_count": 500000,
      "max_non_manifold_edge_count": 16,
      "max_orientation_conflict_edge_count": 16,
      "max_degenerate_face_count": 64,
      "max_duplicate_face_count": 128,
      "max_interior_face_count": 0
    },
    "required_trace_fields": [
      "review_attempts",
      "mesh_rejections",
      "inference_resubmissions",
      "final_decision"
    ]
  },
  "usd_vlm_review": {
    "provider": "nvidia_nim",
    "model": "nvidia/llama-3.1-nemotron-nano-vl-8b-v1",
    "role": "vlm_reviewer",
    "seed": 17,
    "temperature": 0.0,
    "max_image_edge": 1024,
    "response_format": "strict JSON object with keys verdict, confidence, findings"
  },
