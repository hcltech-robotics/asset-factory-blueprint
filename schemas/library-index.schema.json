{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hcltech-robotics.github.io/asset-factory-blueprint/schemas/v1/library-index.schema.json",
  "title": "library index",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "version",
    "domain",
    "items"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+(?:\\.[0-9]+)?(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "materials",
        "textures",
        "usd_assets",
        "knowledge",
        "physical_properties",
        "asset_packs",
        "mixed"
      ]
    },
    "backing_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "name",
          "domain",
          "source",
          "tags"
        ],
        "properties": {
          "item_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "licence": {
            "type": "string"
          },
          "material_class": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "cached": {
            "type": "boolean"
          },
          "obtain": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
