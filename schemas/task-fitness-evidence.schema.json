{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hcltech-robotics.github.io/asset-factory-blueprint/schemas/v1/task-fitness-evidence.schema.json",
  "title": "task fitness evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "format_version",
    "created_at",
    "scope",
    "run_id",
    "request_digest",
    "asset_fingerprint",
    "profile_id",
    "profile_version",
    "protocol",
    "evidence",
    "tests"
  ],
  "properties": {
    "report_id": {"type": "string", "pattern": "^task_fitness_[a-f0-9]{32}$"},
    "format_version": {"const": "2.0.0"},
    "created_at": {"type": "string", "format": "date-time"},
    "scope": {
      "type": "string",
      "enum": ["visualisation", "rigid_body_manipulation", "articulated_training", "redistribution"]
    },
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "request_digest": {"type": "string", "pattern": "^sha256:[A-Fa-f0-9]{64}$"},
    "asset_fingerprint": {"type": "string", "pattern": "^sha256:[A-Fa-f0-9]{64}$"},
    "profile_id": {"type": "string", "minLength": 1},
    "profile_version": {"type": "string", "minLength": 1},
    "runtime_id": {"type": "string"},
    "runtime_version": {"type": "string"},
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_id", "protocol_version", "path", "sha256"],
      "properties": {
        "protocol_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
        "protocol_version": {
          "type": "string",
          "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\:]+$"},
        "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "kind", "path", "sha256"],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^evidence_[a-f0-9]{32}$"},
          "kind": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
          "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\:]+$"},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        }
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["test_id", "status", "scenario", "metric_results", "evidence_ids"],
        "properties": {
          "test_id": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "blocked", "not_run", "not_applicable"]},
          "scenario": {"type": "string", "minLength": 1},
          "metric_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["metric_id", "value", "unit", "expected_min", "expected_max", "tolerance", "status"],
              "properties": {
                "metric_id": {"type": "string", "minLength": 1},
                "value": {"type": "number"},
                "unit": {"type": "string", "minLength": 1},
                "expected_min": {"type": "number"},
                "expected_max": {"type": "number"},
                "tolerance": {"type": "number", "minimum": 0},
                "status": {"type": "string", "enum": ["pass", "blocked"]}
              }
            }
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^evidence_[a-f0-9]{32}$"}
          }
        }
      }
    },
    "extensions": {"type": "object", "additionalProperties": true}
  }
}
