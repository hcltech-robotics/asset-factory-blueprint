{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hcltech-robotics.github.io/asset-factory-blueprint/schemas/v1/evaluation-manifest.schema.json",
  "title": "evaluation manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "version",
    "status",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+(?:\\.[0-9]+)?(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "asset_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposal",
        "validated",
        "review_required",
        "blocked",
        "released",
        "not_validated"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "kind",
          "uri",
          "checksum"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "checksum": {
            "type": "string",
            "anyOf": [
              {"pattern": "^(?:sha256:)?[A-Fa-f0-9]{64}$"},
              {"const": "sha256:example"}
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "provider_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider",
          "model",
          "role",
          "prompt_checksum"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "prompt_checksum": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "review_required",
        "approved",
        "rejected"
      ]
    },
    "task_fitness": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "scope", "required_test_ids", "tests", "report_path", "report_sha256", "blocked_reasons"],
      "properties": {
        "status": {"type": "string", "enum": ["pass", "blocked"]},
        "scope": {"type": "string"},
        "required_test_ids": {"type": "array", "items": {"type": "string"}},
        "tests": {"type": "array", "items": {"type": "object"}},
        "report_path": {"type": "string"},
        "report_sha256": {"type": "string", "pattern": "^(?:[A-Fa-f0-9]{64})?$"},
        "blocked_reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
