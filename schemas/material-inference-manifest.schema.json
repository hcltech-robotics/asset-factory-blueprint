{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hcltech-robotics.github.io/asset-factory-blueprint/schemas/v1/material-inference-manifest.schema.json",
  "title": "material inference manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "asset_id",
    "source_manifest_id",
    "material_library_id",
    "component_materials",
    "evidence",
    "provider_trace",
    "review_status",
    "physical_property_proposals"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+(?:\\.[0-9]+)?(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "asset_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposal",
        "validated",
        "review_required",
        "blocked",
        "released",
        "not_validated"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "kind",
          "uri",
          "checksum"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "checksum": {
            "type": "string",
            "anyOf": [
              {"pattern": "^(?:sha256:)?[A-Fa-f0-9]{64}$"},
              {"const": "sha256:example"}
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "provider_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider",
          "model",
          "role",
          "prompt_checksum"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "prompt_checksum": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "review_required",
        "approved",
        "rejected"
      ]
    },
    "source_manifest_id": {
      "type": "string"
    },
    "material_library_id": {
      "type": "string"
    },
    "component_materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prim_path",
          "component_label",
          "candidate_materials",
          "selected_material",
          "selection_status",
          "pbr_binding_target",
          "visual_evidence_ids",
          "metadata_evidence_ids",
          "confidence",
          "uncertainty_reason",
          "requires_human_review"
        ],
        "properties": {
          "prim_path": {
            "type": "string"
          },
          "component_label": {
            "type": "string"
          },
          "candidate_materials": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "selected_material": {
            "type": [
              "string",
              "null"
            ]
          },
          "selection_status": {
            "type": "string",
            "enum": [
              "proposal",
              "validated",
              "review_required",
              "rejected"
            ]
          },
          "pbr_binding_target": {
            "type": "string"
          },
          "visual_evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata_evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "number"
          },
          "uncertainty_reason": {
            "type": "string"
          },
          "requires_human_review": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "physical_property_proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "property_name",
          "value",
          "unit",
          "method",
          "confidence",
          "evidence_ids",
          "validation_status"
        ],
        "additionalProperties": true
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
