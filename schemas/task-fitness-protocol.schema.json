{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hcltech-robotics.github.io/asset-factory-blueprint/schemas/v1/task-fitness-protocol.schema.json",
  "title": "task fitness protocol",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_id",
    "protocol_version",
    "status",
    "scope",
    "authority",
    "approval_id",
    "approved_at",
    "tests"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "protocol_version": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "status": {"type": "string", "enum": ["draft", "approved", "withdrawn"]},
    "scope": {
      "type": "string",
      "enum": ["visualisation", "rigid_body_manipulation", "articulated_training", "redistribution"]
    },
    "authority": {"type": "string", "minLength": 1},
    "approval_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "approved_at": {"type": "string", "format": "date-time"},
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["test_id", "scenario", "metrics"],
        "properties": {
          "test_id": {"type": "string", "minLength": 1},
          "scenario": {"type": "string", "minLength": 1},
          "metrics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["metric_id", "unit", "expected_min", "expected_max", "tolerance"],
              "properties": {
                "metric_id": {"type": "string", "minLength": 1},
                "unit": {"type": "string", "minLength": 1},
                "expected_min": {"type": "number"},
                "expected_max": {"type": "number"},
                "tolerance": {"type": "number", "minimum": 0}
              }
            }
          }
        }
      }
    },
    "extensions": {"type": "object", "additionalProperties": true}
  }
}
